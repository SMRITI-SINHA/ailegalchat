# Chakshi Legal AI Platform - Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE (Required)
# ===========================================
DATABASE_URL=postgresql://username:password@host:5432/database_name

# ===========================================
# AI SERVICES (Required)
# ===========================================
# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Perplexity API Key - Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here

# ===========================================
# LEGAL RESEARCH (Required for Research features)
# ===========================================
# Indian Kanoon API Token - Get from https://api.indiankanoon.org/
INDIAN_KANOON_API_TOKEN=your-indian-kanoon-api-token-here

# ===========================================
# AUTHENTICATION (Required for Google Login)
# ===========================================
# Google OAuth Credentials - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Session Secret - Generate a random string (min 32 characters)
SESSION_SECRET=your-random-session-secret-min-32-characters

# ===========================================
# SERVER CONFIGURATION (Optional)
# ===========================================
PORT=5000
NODE_ENV=production

# ===========================================
# NOTES
# ===========================================
# 1. Never commit your actual .env file to git
# 2. Add .env to your .gitignore file
# 3. For Replit deployment, add these as Secrets in the Secrets tab
# 4. For MERN integration, these should be set in your backend server
